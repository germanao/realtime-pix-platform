{
  "Saga": {
    "StepTimeoutSeconds": 30,
    "SimulatedCreditTimeoutSeconds": 8,
    "CompensationTimeoutSeconds": 30,
    "TimeoutBatchSize": 50,
    "AllowFailureSimulation": true
  },
  "EventBus": {
    "Provider": "File",
    "Directory": "../../.local/event-bus",
    "ServiceBus": {
      "TopicName": "platform-events",
      "SubscriptionName": "transaction",
      "MaxConcurrentCalls": 4
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
